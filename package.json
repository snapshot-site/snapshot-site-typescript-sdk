{
  "name": "@snapshot-site/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Snapshot Site API",
  "homepage": "https://snapshot-site.com/api-docs",
  "keywords": [
    "snapshot",
    "screenshot",
    "visual-diff",
    "api",
    "sdk"
  ],
  "license": "MIT",
  "author": "Snapshot Site",
  "type": "commonjs",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf build",
    "prepare": "pnpm run build",
    "test": "pnpm run build && node --test test/*.test.cjs",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
